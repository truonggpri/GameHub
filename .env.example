# Client-side Environment Variables (for Vite)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Server Environment Variables
PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/gamehub?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password

# Google OAuth (both client and server need this)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# AI Service (Qwen/Alibaba)
AI_PROVIDER=qwen
AI_API_KEY=your_qwen_api_key
AI_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen3.5-plus

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=YourApp <no-reply@yourdomain.com>

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_SUCCESS_URL=http://localhost:5173/payment/success
STRIPE_CANCEL_URL=http://localhost:5173/payment/cancel

# CORS (optional - defaults to localhost:5173)
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
